## Frontend (Next.js) environment variables
##
## Copy to `.env.local` for local development:
##   cp .env.example .env.local

# Backend base URL (Express server)
# Used by the Next.js API proxy route at `app/api/math/solve/route.ts`.
MATH_API_BASE_URL=http://localhost:9000

# Optional: if you need to access the backend directly from the browser
# (not recommended; prefer the Next.js `/api/*` proxy to avoid CORS issues).
NEXT_PUBLIC_MATH_API_BASE_URL=http://localhost:9000

# Optional: enable static export build (disables API routes!)
# NEXT_OUTPUT=export

